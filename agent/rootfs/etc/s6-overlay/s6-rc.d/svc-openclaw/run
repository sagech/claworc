#!/command/with-contenv bash

export HOME=/home/claworc

# Initialize config on first run
if [ ! -f "/home/claworc/.openclaw/openclaw.json" ]; then
    echo "Initializing OpenClaw..."
    mkdir -p /home/claworc/.openclaw
    chown claworc:claworc /home/claworc/.openclaw
    s6-setuidgid claworc openclaw doctor --fix || echo "Doctor finished with exit code $?"

    s6-setuidgid claworc openclaw config set logging.file /var/log/claworc/openclaw.log
    if [ -f "/defaults/browser.json" ]; then
        s6-setuidgid claworc openclaw config set browser "$(cat /defaults/browser.json)" --json
    fi
fi

# Ensure workspace exists
if [ ! -d "/home/claworc/.openclaw/workspace" ]; then
    echo "Creating agent workspace..."
    mkdir -p /tmp/openclaw-$(id -u claworc)
    chown claworc:claworc /tmp/openclaw-$(id -u claworc)
    s6-setuidgid claworc openclaw onboard --non-interactive --accept-risk --mode local || echo "Onboard finished with exit code $?"
fi

# Always ensure gateway settings are correct
s6-setuidgid claworc openclaw config set gateway.mode local
s6-setuidgid claworc openclaw config set gateway.bind localhost
s6-setuidgid claworc openclaw config set gateway.controlUi.dangerouslyDisableDeviceAuth true

# Set Control UI base path for reverse proxy
if [ -n "$CLAWORC_INSTANCE_ID" ]; then
    s6-setuidgid claworc openclaw config set gateway.controlUi.basePath "/openclaw/${CLAWORC_INSTANCE_ID}/"
fi

# Set token if provided
if [ -n "$OPENCLAW_GATEWAY_TOKEN" ]; then
    s6-setuidgid claworc openclaw config set gateway.auth.token "$OPENCLAW_GATEWAY_TOKEN"
fi

chown -R claworc:claworc /home/claworc/.openclaw

echo "Starting OpenClaw Gateway (foreground) as claworc..."
exec bash -c "tail -f /dev/null | s6-setuidgid claworc /usr/bin/openclaw gateway run >> /var/log/claworc/openclaw.log 2>&1"
